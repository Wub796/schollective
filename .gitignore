# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.aider*

# AI agent configs (local dev tools, not needed for deployment)
.agent/

# Legacy vanilla prototype (superseded by Next.js app)
_legacy_vanilla/

# Database migration scripts (run manually, not part of the app)
*.sql

# Dev utility scripts
scripts/

# IDE settings
.vscode/

# One-off test files
test_btn.css

# Default Next.js placeholder assets (not used in the app)
public/file.svg
public/globe.svg
public/window.svg
public/next.svg
public/vercel.svg
public/dark-fluid.png
public/hero-glass.png
